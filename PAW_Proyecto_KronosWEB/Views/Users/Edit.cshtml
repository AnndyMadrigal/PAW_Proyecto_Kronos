@model UserModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Editar perfil";
    var roleOptions = new[]
    {
        new { Text = "Administrador", Value = "Administrador" },
        new { Text = "Colaborador", Value = "Colaborador" },
        new { Text = "Paciente", Value = "Paciente" }
    };
}

<div class="p-6 space-y-6 max-w-4xl mx-auto">
    <div>
        <h1 class="text-2xl font-semibold text-gray-800 dark:text-white/90">Editar perfil</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Cambia el perfil o el estado del usuario seleccionado.</p>
    </div>

    @if (TempData["MensajeError"] != null)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700 dark:border-red-500/20 dark:bg-red-500/10 dark:text-red-400">@TempData["MensajeError"]</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.warning_message))
    {
        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800 dark:border-amber-500/20 dark:bg-amber-500/10 dark:text-amber-300">
            @Model.warning_message
            @if (Model.pending_appointments_count > 0)
            {
                <div class="mt-1 text-xs">Citas pendientes detectadas: @Model.pending_appointments_count</div>
            }
        </div>
    }

    @if (Model.is_unique_admin)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700 dark:border-red-500/20 dark:bg-red-500/10 dark:text-red-400">
            No se puede desactivar ni quitar el perfil de administrador porque es la única cuenta activa con ese rol.
        </div>
    }

    <form asp-action="Edit" method="post" class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-white/[0.03] space-y-5">
        @Html.AntiForgeryToken()
        <input asp-for="id" type="hidden" />

        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
            <div>
                <label class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Nombre</label>
                <input asp-for="full_name" readonly class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-700 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300" />
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Correo</label>
                <input asp-for="email" readonly class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-700 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300" />
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Perfil</label>
                <select asp-for="role_name" class="w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-800 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-white">
                    <option value="">Selecciona un perfil</option>
                    @foreach (var option in roleOptions)
                    {
                        <option value="@option.Value" @(Model.role_name == option.Value ? "selected" : "")>@option.Text</option>
                    }
                </select>
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Estado</label>
                <select asp-for="is_active" class="w-full rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-800 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-white">
                    <option value="true">Activo</option>
                    <option value="false">Inactivo</option>
                </select>
            </div>
        </div>

        @if (Model.has_pending_appointments)
        {
            <div class="flex items-start gap-3 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800 dark:border-amber-500/20 dark:bg-amber-500/10 dark:text-amber-300">
                <input asp-for="allow_pending_appointments" type="checkbox" class="mt-1 h-4 w-4 rounded border-gray-300 text-brand-500 focus:ring-brand-500" />
                <label asp-for="allow_pending_appointments" class="leading-6">
                    Confirmo que deseo continuar aunque el usuario tenga citas pendientes.
                </label>
            </div>
        }

        <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
            <a asp-action="Index" class="inline-flex items-center justify-center rounded-xl border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300">Cancelar</a>
            <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-brand-500 px-4 py-2.5 text-sm font-medium text-white hover:bg-brand-600">Guardar cambios</button>
        </div>
    </form>
</div>
